<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgBrowseFanart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_fanart_2" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/panel_overlay" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header bar -->
        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#CC080810"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FF00DCFF"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/card_nova_selector"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Live TV"
                android:textColor="@color/nova_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Search field (initially compact) -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="220dp"
                android:layout_height="38dp"
                android:background="@drawable/input_bg"
                android:hint="Search..."
                android:textColor="@android:color/white"
                android:textColorHint="#66FFFFFF"
                android:textSize="13sp"
                android:padding="8dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="6dp"
                android:focusableInTouchMode="false"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:layout_marginEnd="12dp"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvUserBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/card_nova"
                android:text="USER"
                android:textColor="@color/nova_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <!-- Body: sidebar + content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Category sidebar -->
            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#99080810">

                <TextView
                    android:id="@+id/tvCategoryCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp"
                    android:text="CATEGORIES"
                    android:textColor="#6600DCFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.15" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCategories"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="none" />

            </LinearLayout>

            <!-- Content area -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="8dp">

                    <!-- Continue Watching row (shown when available) -->
                    <LinearLayout
                        android:id="@+id/continueWatchingSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Continue Watching"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:paddingStart="4dp"
                            android:paddingBottom="8dp"
                            android:letterSpacing="0.05" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvContinueWatching"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginBottom="12dp" />

                    </LinearLayout>

                    <!-- Content count -->
                    <TextView
                        android:id="@+id/tvContentCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#6600DCFF"
                        android:textSize="10sp"
                        android:letterSpacing="0.15"
                        android:paddingStart="4dp"
                        android:paddingBottom="6dp"
                        android:visibility="gone" />

                    <!-- Main content grid -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvContent"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:clipToPadding="false"
                        android:scrollbars="vertical" />

                </LinearLayout>

                <!-- Loading overlay -->
                <FrameLayout
                    android:id="@+id/loadingOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#88000000"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/nova_primary" />

                    <TextView
                        android:id="@+id/tvLoadingMsg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="70dp"
                        android:text="Loading..."
                        android:textColor="#AAFFFFFF"
                        android:textSize="12sp" />

                </FrameLayout>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
