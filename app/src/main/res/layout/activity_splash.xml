<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nova_bg">

    <!-- Glow circle -->
    <View
        android:id="@+id/glowCircle"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_glow_circle"
        android:alpha="0" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/logoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOCA TV"
            android:textColor="@color/nova_primary"
            android:textSize="72sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-light"
            android:alpha="0" />

        <TextView
            android:id="@+id/taglineText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="NOVA — The Cinema Experience"
            android:textColor="#99FFFFFF"
            android:textSize="16sp"
            android:letterSpacing="0.2"
            android:alpha="0" />

    </LinearLayout>

    <!-- Auto-update progress — shown during silent background download -->
    <LinearLayout
        android:id="@+id/layoutUpdateProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="vertical"
        android:paddingStart="64dp"
        android:paddingEnd="64dp"
        android:paddingBottom="56dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvUpdateStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"
            android:text="Updating SocaTV Nova…"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.04" />

        <ProgressBar
            android:id="@+id/progressUpdate"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/nova_primary"
            android:progressBackgroundTint="#33FFFFFF" />

    </LinearLayout>

</FrameLayout>
