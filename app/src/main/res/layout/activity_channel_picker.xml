<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF080810">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC080810"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnPickerBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FF00DCFF"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/card_nova_selector"
            android:contentDescription="Back"
            android:nextFocusRight="@id/rvPickerCategories" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="SELECT CHANNEL"
            android:textColor="#FF00DCFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvPickerHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browse channels and press OK to add"
            android:textColor="#66FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Content: categories left + channels right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Category sidebar -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPickerCategories"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="#AA040410"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Channel grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPickerChannels"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="8dp" />

    </LinearLayout>


</LinearLayout>
