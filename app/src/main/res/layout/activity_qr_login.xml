<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF080810">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_nova_gradient" />

    <!-- Centered card -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/card_nova"
        android:padding="40dp">

        <!-- Left: Instructions -->
        <LinearLayout
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="40dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnQrBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FF00DCFF"
                android:padding="8dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/card_nova_selector"
                android:contentDescription="Back"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIGN IN WITH PHONE"
                android:textColor="@color/nova_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Connect your phone to the same Wi-Fi network"
                android:textColor="#BBFFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Open your camera and scan the QR code"
                android:textColor="#BBFFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Enter your credentials in the browser"
                android:textColor="#BBFFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvQrStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Starting…"
                android:textColor="@color/nova_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvQrSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⟳"
                android:textColor="#AA00DCFF"
                android:textSize="20sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvQrUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Right: QR Code -->
        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:background="#FF080810"
            android:padding="8dp">

            <ImageView
                android:id="@+id/ivQrCode"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:contentDescription="QR Code" />

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
