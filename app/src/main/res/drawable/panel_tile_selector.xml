<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#3300DCFF" />
                    <corners android:radius="10dp" />
                    <stroke android:width="3dp" android:color="#FF00DCFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#3300DCFF" />
                    <corners android:radius="10dp" />
                    <stroke android:width="3dp" android:color="#FF00DCFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#5500DCFF" />
                    <corners android:radius="10dp" />
                    <stroke android:width="2dp" android:color="#FF00DCFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CC141422" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#3300DCFF" />
        </shape>
    </item>
</selector>
