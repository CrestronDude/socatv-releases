<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#2200DCFF" />
            <stroke android:width="2dp" android:color="#FF00DCFF" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#3300DCFF" />
            <stroke android:width="1.5dp" android:color="#CC00DCFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#1A00DCFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#221A1A30" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
        </shape>
    </item>
</selector>
