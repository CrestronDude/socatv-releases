<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#2200DCFF" />
            <stroke android:width="1.5dp" android:color="#FF00DCFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#1A00DCFF" />
            <stroke android:width="1dp" android:color="#CC00DCFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#CC141422" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>
</selector>
